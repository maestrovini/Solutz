{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "role": { "type": "string", "enum": ["admin", "broker", "agency"], "description": "User role" }
      },
      "required": ["uid", "email", "role"]
    },
    "Client": {
      "title": "Client",
      "description": "Client information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Client ID" },
        "name": { "type": "string", "description": "Client name" },
        "email": { "type": "string", "format": "email", "description": "Client email" },
        "phone": { "type": "string", "description": "Client phone" },
        "brokerId": { "type": "string", "description": "Broker ID" },
        "status": { "type": "string", "enum": ["Aprovado", "Condicionado", "Negado"], "description": "Client status" },
        "statusDate": { "type": "string", "format": "date", "description": "Credit status date" },
        "birthDate": { "type": "string", "format": "date", "description": "Birth date" },
        "cpf": { "type": "string", "description": "CPF" },
        "pis": { "type": "string", "description": "PIS" },
        "phone2": { "type": "string", "description": "Secondary phone" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "email"]
    },
    "Process": {
      "title": "Process",
      "description": "Financing process information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Process ID" },
        "clientId": { "type": "string", "description": "Client ID" },
        "participants": { 
          "type": "array", 
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["buyer", "seller", "broker", "agency", "proxy"] },
              "name": { "type": "string" },
              "representsIds": { "type": "array", "items": { "type": "string" } }
            }
          },
          "description": "List of participants" 
        },
        "type": { "type": "string", "description": "Process type" },
        "status": { "type": "string", "description": "Process status" },
        "stage": { "type": "string", "description": "Process stage" },
        "bankId": { "type": "string", "description": "Bank ID" },
        "purchaseValue": { "type": "number", "description": "Purchase value" },
        "financingValue": { "type": "number", "description": "Financing value" },
        "value": { "type": "number", "description": "Process value" },
        "agency": { "type": "string", "description": "Bank agency" },
        "brokerId": { "type": "string", "description": "Broker ID" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["clientId", "type", "status"]
    },
    "Agency": {
      "title": "Agency",
      "description": "Real estate agency information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Agency ID" },
        "name": { "type": "string", "description": "Agency name" },
        "cnpj": { "type": "string", "description": "Agency CNPJ" },
        "email": { "type": "string", "format": "email", "description": "Agency email" },
        "phone": { "type": "string", "description": "Agency phone" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name"]
    },
    "Broker": {
      "title": "Broker",
      "description": "Broker information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Broker ID" },
        "name": { "type": "string", "description": "Broker name" },
        "creci": { "type": "string", "description": "Broker CRECI" },
        "email": { "type": "string", "format": "email", "description": "Broker email" },
        "phone": { "type": "string", "description": "Broker phone" },
        "birthDate": { "type": "string", "format": "date", "description": "Broker birth date" },
        "agencyId": { "type": "string", "description": "Agency ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name"]
    },
    "Bank": {
      "title": "Bank",
      "description": "Bank information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Bank ID" },
        "name": { "type": "string", "description": "Bank name" },
        "processTypes": { "type": "array", "description": "Supported process types" },
        "logoUrl": { "type": "string", "description": "Bank logo URL" }
      },
      "required": ["name"]
    },
    "Property": {
      "title": "Property",
      "description": "Property information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Property ID" },
        "address": { "type": "string", "description": "Property address" },
        "number": { "type": "string", "description": "Property number" },
        "complement": { "type": "string", "description": "Property complement" },
        "neighborhood": { "type": "string", "description": "Property neighborhood (Bairro)" },
        "cep": { "type": "string", "description": "Property CEP (Postal Code)" },
        "city": { "type": "string", "description": "Property city" },
        "state": { "type": "string", "description": "Property state" },
        "zone": { "type": "string", "description": "Property zone" },
        "registrationNumber": { "type": "string", "description": "Property registration number (Matrícula)" },
        "additionalInfo": { "type": "string", "description": "Additional information" },
        "price": { "type": "number", "description": "Property price (Valor)" },
        "type": { "type": "string", "enum": ["Casa", "Apartamento", "Terreno", "Comercial"], "description": "Property type" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Update timestamp" }
      },
      "required": ["address", "city", "state", "type"]
    },
    "Product": {
      "title": "Product",
      "description": "Sold product contract details tracked inside the system",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Product transaction tracking ID" },
        "clientId": { "type": "string", "description": "Associated Client ID" },
        "name": { "type": "string", "description": "Product specific description" },
        "bankId": { "type": "string", "description": "Associated Bank ID" },
        "category": { "type": "string", "enum": ["Financiamento", "Consórcio", "Seguro", "Crédito", "Outro"], "description": "Product category" },
        "value": { "type": "number", "description": "Sold transaction credit/loan value" },
        "interestRate": { "type": "string", "description": "Interest rate or admin fee details" },
        "termMonths": { "type": "number", "description": "Repayment term in months" },
        "commissionPercent": { "type": "number", "description": "Commission percent" },
        "commissionValue": { "type": "number", "description": "Commission earned value" },
        "status": { "type": "string", "enum": ["Em andamento", "Finalizado", "Cancelado"], "description": "Coarse transaction status" },
        "stage": { "type": "string", "enum": ["Simulação", "Proposta Gerada", "Sob Análise", "Aprovado", "Emitido / Pago"], "description": "Active workflow stage" },
        "brokerId": { "type": "string", "description": "Responsible broker ID" },
        "notes": { "type": "string", "description": "General observations" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["clientId", "name", "bankId", "category", "value", "status", "stage"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Clients"
    },
    "/processes/{processId}": {
      "schema": "Process",
      "description": "Processes"
    },
    "/agencies/{agencyId}": {
      "schema": "Agency",
      "description": "Agencies"
    },
    "/brokers/{brokerId}": {
      "schema": "Broker",
      "description": "Brokers"
    },
    "/banks/{bankId}": {
      "schema": "Bank",
      "description": "Banks"
    },
    "/properties/{propertyId}": {
      "schema": "Property",
      "description": "Properties"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products"
    }
  }
}
